# ─── App Configuration ─────────────────────────────────────────────
# Base URL for the application (used in production builds)
VITE_APP_BASE_URL=http://localhost:8080

# Application title shown in the browser tab
VITE_APP_TITLE=Financial Data Grid

# ─── Data Configuration ────────────────────────────────────────────
# Path to the transactions JSON file (relative to public/)
VITE_TRANSACTIONS_PATH=/transactions.json

# Number of rows to generate (default: 1000000)
VITE_DATA_ROW_COUNT=1000000

# ─── Grid Configuration ────────────────────────────────────────────
# Height of each row in pixels (fixed-height virtualization)
VITE_ROW_HEIGHT=40

# Number of buffer rows to render above/below viewport
VITE_BUFFER_ROWS=10

# ─── Docker / Nginx ────────────────────────────────────────────────
# Internal nginx port (do not change)
NGINX_PORT=80

# Host machine port mapping
HOST_PORT=8080
